<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<AnchorPane prefHeight="540" prefWidth="960" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.SetSessionController">
   <VBox alignment="CENTER" spacing="10"
         AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
         AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
      <Label fx:id="progressLabel" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
      <Label fx:id="questionLabel" style="-fx-font-size: 18px;"/>

      <Label fx:id="answerLabel"/>

      <TextField fx:id="answerField" promptText="Enter answer"/>

      <Label fx:id="resultLabel"/>

      <HBox alignment="CENTER" spacing="10">
         <Button fx:id="showAnswerButton" text="Show Answer" onAction="#handleShowAnswer"/>
         <Button fx:id="correctButton" text="Mark Correct" onAction="#handleCorrect"/>
         <Button fx:id="wrongButton"   text="Mark Wrong"   onAction="#handleWrong"/>
         <Button fx:id="nextButton" text="Next" onAction="#handleNext"/>
         <Button fx:id="submitButton" text="Submit" onAction="#handleSubmit"/>
      </HBox>

   </VBox>
</AnchorPane>

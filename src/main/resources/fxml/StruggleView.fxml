<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" prefHeight="540" prefWidth="960" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="app.StruggleViewController">

    <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Separator/>

    <Label text="Struggle areas (higher = more difficulty):"
           style="-fx-font-size: 13px; -fx-text-fill: #555;"/>

    <ScrollPane fitToWidth="true" prefHeight="320" style="-fx-border-color: transparent;">
        <VBox fx:id="struggleListVBox" spacing="4" style="-fx-padding: 4;"/>
    </ScrollPane>

    <Separator/>

    <HBox spacing="10">
        <Button text="Back" onAction="#handleBack"/>
        <Button fx:id="practiceButton" onAction="#handlePractice"
                style="-fx-font-weight: bold;"/>
    </HBox>
</VBox>

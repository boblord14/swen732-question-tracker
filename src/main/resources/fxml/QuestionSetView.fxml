<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane fx:controller="app.QuestionSetViewController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="960" prefHeight="540">
    <children>
        <VBox spacing="10" layoutX="40" layoutY="20" prefWidth="880">
            <HBox spacing="10">
                <Label fx:id="setTitleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Back" onAction="#handleBack"/>
            </HBox>

            <HBox spacing="8">
                <Button text="Add Question" onAction="#handleAddQuestion"/>
                <Button text="Take Set" onAction="#handleTakeSet"/>
            </HBox>

            <Label text="Questions:" style="-fx-font-weight: bold;"/>
            <ScrollPane fitToWidth="true" prefHeight="220">
                <content>
                    <VBox fx:id="questionListVBox" spacing="6">
                        <padding>
                            <Insets top="8" right="8" bottom="8" left="8"/>
                        </padding>
                    </VBox>
                </content>
            </ScrollPane>

            <VBox fx:id="sessionBox" spacing="8" visible="false">
                <Label fx:id="sessionQuestionLabel" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label fx:id="sessionAnswerLabel" style="-fx-font-size: 14px;"/>
                <HBox spacing="8">
                    <Button text="Show Answer" onAction="#handleShowAnswer"/>
                    <Button text="Mark Correct" onAction="#handleMarkCorrect"/>
                    <Button text="Mark Wrong" onAction="#handleMarkWrong"/>
                    <Button text="Next" onAction="#handleNext"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

        </VBox>
    </children>
</AnchorPane>

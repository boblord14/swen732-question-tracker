<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:controller="app.MainController"
            xmlns:fx="http://javafx.com/fxml"
            prefWidth="400" prefHeight="300">
    <children>

        <VBox layoutX="200" layoutY="160" spacing="12" prefWidth="560" styleClass="card">
            <Label text="Question Tracker" styleClass="title" />
            <Button fx:id="questionSetsButton" text="Question Sets" onAction="#handleQuestionSets" styleClass="button ghost" />
            <Button fx:id="userStruggleButton" text="View Your Struggles" onAction="#handleViewStruggles" styleClass="button ghost" />
            <Button fx:id="classListButton"
                    text="Class List"
                    onAction="#handleLoad"/>

            <Button fx:id="loginButton"
                    text="login"
                    onAction="#handleLogin"/>

            <Button fx:id="signupButton"
                    text="signup"
                    onAction="#handleSignup"/>
        </VBox>
    </children>
</AnchorPane>